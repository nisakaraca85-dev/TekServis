@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE HTML>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TekServis</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/TekServis.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand text-primary fw-bold" asp-area="" asp-controller="Home" asp-action="Index">TekServis</a>
                <button class="navbar-collapse collapse d-sm-inline-flex justify-content-between" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    
                    @* --- SOL TARAF: ROL KONTROLLÜ MENÜ BUTONLARI --- *@
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="ServisKayit" asp-action="Index">Servis Kayıtları</a>
                        </li>

                        @{
                            var rol = HttpContextAccessor.HttpContext?.Session.GetString("KullaniciRol");
                            var kullaniciAd = HttpContextAccessor.HttpContext?.Session.GetString("KullaniciAd");
                        }

                        @* Kural 1: Müşteri Yönetimi'ni hem SuperAdmin hem Admin görebilir *@
                        @if (rol == "SuperAdmin" || rol == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Musteri" asp-action="Index">Müşteri Yönetimi</a>
                            </li>
                        }

                        @* Kural 2: Cihaz Havuzu'nu SADECE SuperAdmin görebilir *@
                        @if (rol == "SuperAdmin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Cihaz" asp-action="Index">Cihaz Havuzu</a>
                            </li>
                        }

                        @* Kural 3: Teknisyen Yönetimi'ni SADECE SuperAdmin görebilir *@
                        @if (rol == "SuperAdmin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Teknisyen" asp-action="Index">Teknisyen Yönetimi</a>
                            </li>
                        }
                    </ul>

                    @* --- SAĞ TARAF: GİRİŞ YAPMIŞ KULLANICI BİLGİSİ VE ÇIKIŞ BUTONU --- *@
                    <ul class="navbar-nav">
                        @if (!string.IsNullOrEmpty(kullaniciAd))
                        {
                            <li class="nav-item">
                                <span class="nav-link text-muted me-2">
                                    Hoş geldin, <b>@kullaniciAd</b> <span class="badge bg-secondary ms-1">@rol</span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm mt-1" asp-controller="Account" asp-action="Logout">Çıkış</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary btn-sm mt-1" asp-controller="Account" asp-action="Login">Giriş Yap</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted text-center mt-4 pt-3">
        <div class="container">
            &copy; 2026 - TekServis Yönetim Paneli
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>