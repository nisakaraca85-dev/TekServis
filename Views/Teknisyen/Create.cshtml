@model TekServis.Models.Teknisyen

@{
    ViewData["Title"] = "Yeni Teknisyen Ekle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="bi bi-person-plus-fill"></i> Yeni Teknisyen Kaydı</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="AdSoyad" class="form-label">Adı Soyadı</label>
                            <input asp-for="AdSoyad" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="UzmanlikAlani" class="form-label">Uzmanlık Alanı</label>
                            <input asp-for="UzmanlikAlani" class="form-control" placeholder="Örn: Telefon, Beyaz Eşya, Bilgisayar" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Telefon" class="form-label">Telefon Numarası</label>
                            <input asp-for="Telefon" class="form-control" />
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Listeye Geri Dön</a>
                            <button type="submit" class="btn btn-info text-white">Teknisyeni Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>