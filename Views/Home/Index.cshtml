@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-dark"><i class="bi bi-cpu-fill text-primary"></i> TekServis Otomasyonu</h1>
        <p class="lead text-muted">Teknik Servis Yönetim ve Takip Sistemine Hoş Geldiniz.</p>
        <hr class="my-4" style="width: 200px; margin: 0 auto; border-top: 3px solid #0d6efd;">
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm h-100 border-start border-info border-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="card-title text-info fw-bold"><i class="bi bi-people-fill"></i> Müşteri Yönetimi</h5>
                        <p class="card-text text-muted">Sisteme kayıtlı müşterileri listeleyin, yeni müşteri profilleri oluşturun.</p>
                    </div>
                    <a asp-controller="Musteri" asp-action="Index" class="btn btn-outline-info mt-3 w-100">Müşterilere Git</a>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm h-100 border-start border-success border-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="card-title text-success fw-bold"><i class="bi bi-wrench-adjustable"></i> Teknisyen Yönetimi</h5>
                        <p class="card-text text-muted">Saha ve merkez teknisyenlerinin uzmanlık alanlarını ve bilgilerini yönetin.</p>
                    </div>
                    <a asp-controller="Teknisyen" asp-action="Index" class="btn btn-outline-success mt-3 w-100">Teknisyenlere Git</a>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm h-100 border-start border-warning border-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="card-title text-warning fw-bold"><i class="bi bi-laptop-fill"></i> Cihaz Havuzu</h5>
                        <p class="card-text text-muted">Müşterilere ait arızalı veya teslim alınmış cihazların marka/model takibini yapın.</p>
                    </div>
                    <a asp-controller="Cihaz" asp-action="Index" class="btn btn-outline-warning mt-3 w-100">Cihazlara Git</a>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm h-100 border-start border-primary border-4">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="card-title text-primary fw-bold"><i class="bi bi-tools"></i> Servis İşlemleri</h5>
                        <p class="card-text text-muted">Hangi cihaz hangi aşamada? Servis durumlarını, fiyatlandırmaları ve süreçleri yönetin.</p>
                    </div>
                    <a asp-controller="ServisKayit" asp-action="Index" class="btn btn-outline-primary mt-3 w-100">Servis Kayıtlarına Git</a>
                </div>
            </div>
        </div>
    </div>
</div>