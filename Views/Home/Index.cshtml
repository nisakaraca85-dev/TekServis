@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Ana Sayfa";
    var kullaniciRol = HttpContextAccessor.HttpContext?.Session.GetString("KullaniciRol");
}

<div class="text-center my-4">
    <h1 class="display-4 fw-bold text-dark">TekServis Otomasyonu</h1>
    <p class="lead text-muted">Teknik Servis Yönetim ve Takip Sistemine Hoş Geldiniz.</p>
</div>

<div class="container mt-5">
    <div class="row g-4 justify-content-center">
        
        @* --- 1. KART: MÜŞTERİ YÖNETİMİ (SuperAdmin ve Stajyer Görebilir) --- *@
        @if (kullaniciRol == "SuperAdmin" || kullaniciRol == "Stajyer")
        {
            <div class="col-md-5">
                <div class="card h-100 border-info shadow-sm">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title text-info fw-bold">Müşteri Yönetimi</h5>
                            <p class="card-text text-secondary">Sisteme kayıtlı müşterileri listeleyin, yeni müşteri profilleri oluşturun.</p>
                        </div>
                        <a asp-controller="Musteri" asp-action="Index" class="btn btn-outline-info w-100 mt-3">Müşterilere Git</a>
                    </div>
                </div>
            </div>
        }

        @* --- 2. KART: TEKNİSYEN YÖNETİMİ (SADECE SuperAdmin Görebilir) --- *@
        @if (kullaniciRol == "SuperAdmin")
        {
            <div class="col-md-5">
                <div class="card h-100 border-success shadow-sm">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title text-success fw-bold">Teknisyen Yönetimi</h5>
                            <p class="card-text text-secondary">Saha ve merkez teknisyenlerinin uzmanlık alanlarını ve bilgilerini yönetin.</p>
                        </div>
                        <a asp-controller="Teknisyen" asp-action="Index" class="btn btn-outline-success w-100 mt-3">Teknisyenlere Git</a>
                    </div>
                </div>
            </div>
        }

        @* --- 3. KART: CİHAZ HAVUZU (SuperAdmin ve Stajyer Görebilir) --- *@
        @if (kullaniciRol == "SuperAdmin" || kullaniciRol == "Stajyer")
        {
            <div class="col-md-5">
                <div class="card h-100 border-warning shadow-sm">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title text-warning fw-bold">Cihaz Havuzu</h5>
                            <p class="card-text text-secondary">Müşterilere ait arızalı veya teslim alınmış cihazların marka/model takibini yapın.</p>
                        </div>
                        <a asp-controller="Cihaz" asp-action="Index" class="btn btn-outline-warning w-100 mt-3">Cihazlara Git</a>
                    </div>
                </div>
            </div>
        }

        @* --- 4. KART: SERVİS İŞLEMLERİ (Herkes Görebilir) --- *@
        <div class="col-md-5">
            <div class="card h-100 border-primary shadow-sm">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="card-title text-primary fw-bold">Servis İşlemleri</h5>
                        <p class="card-text text-secondary">Hangi cihaz hangi aşamada? Servis durumlarını, fiyatlandırmaları ve süreçleri yönetin.</p>
                    </div>
                    <a asp-controller="ServisKayit" asp-action="Index" class="btn btn-outline-primary w-100 mt-3">Servis Kayıtlarına Git</a>
                </div>
            </div>
        </div>

    </div>
</div>